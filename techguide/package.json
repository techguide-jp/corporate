{
  "name": "tech-guide-sveltekit",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "lint": "svelte-kit sync && eslint . --max-warnings 0",
    "lint:fix": "svelte-kit sync && eslint . --fix --max-warnings 0",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "validate": "pnpm format:check && pnpm lint && pnpm check && pnpm build",
    "ga:list": "node --env-file-if-exists=.env scripts/ga-admin.mjs list",
    "ga:sync": "node --env-file-if-exists=.env scripts/ga-admin.mjs sync",
    "ga:sync:dry": "node --env-file-if-exists=.env scripts/ga-admin.mjs sync --dry-run",
    "logs:groups": "node --env-file-if-exists=.env scripts/amplify-logs.mjs groups",
    "logs:tail": "node --env-file-if-exists=.env scripts/amplify-logs.mjs tail"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@google-analytics/admin": "^9.0.1",
    "@sveltejs/kit": "^2.55.0",
    "@sveltejs/vite-plugin-svelte": "^7.0.0",
    "amplify-adapter": "^1.3.0",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-svelte": "^3.17.0",
    "globals": "^17.5.0",
    "prettier": "^3.8.3",
    "prettier-plugin-svelte": "^3.5.1",
    "svelte": "^5.0.0",
    "svelte-check": "^4.0.0",
    "typescript": "^5.0.0",
    "typescript-eslint": "^8.58.2",
    "vite": "^7.0.0"
  },
  "packageManager": "pnpm@10.33.0+sha512.10568bb4a6afb58c9eb3630da90cc9516417abebd3fabbe6739f0ae795728da1491e9db5a544c76ad8eb7570f5c4bb3d6c637b2cb41bfdcdb47fa823c8649319",
  "dependencies": {
    "@aws-sdk/client-ssm": "^3.1038.0",
    "resend": "^6.12.2"
  }
}
